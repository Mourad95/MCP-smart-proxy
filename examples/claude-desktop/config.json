{
  "port": 3000,
  "mcpServers": [
    {
      "name": "filesystem",
      "url": "ws://localhost:8080",
      "description": "Filesystem access for Claude Desktop",
      "priority": 1,
      "enabled": true,
      "timeout": 30000
    },
    {
      "name": "github",
      "url": "ws://localhost:8081",
      "description": "GitHub integration for Claude Desktop",
      "priority": 2,
      "enabled": true,
      "timeout": 30000
    }
  ],
  "optimization": {
    "enabled": true,
    "maxContextTokens": 1200,
    "embeddingModel": "Xenova/all-MiniLM-L6-v2",
    "cacheEnabled": true,
    "semanticRouting": true,
    "minRelevanceScore": 0.35
  },
  "logging": {
    "level": "info",
    "format": "text"
  },
  "analytics": {
    "enabled": true,
    "retentionDays": 7,
    "dashboardEnabled": true
  }
}