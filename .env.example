# MCP Smart Proxy Environment Variables
# Copy this file to .env and adjust values as needed

# Dashboard Authentication
# Set a password to protect the dashboard and API endpoints
# If not set, access is unrestricted (development mode)
DASHBOARD_PASSWORD=your-secure-password-here

# JWT Secret for dashboard authentication tokens
# Auto-generated if not provided
# DASHBOARD_JWT_SECRET=your-jwt-secret-here

# Server Configuration
PORT=3000
NODE_ENV=development

# MCP Server URLs
# MCP_FILESYSTEM_URL=ws://localhost:8080
# MCP_GITHUB_URL=ws://localhost:8081
# MCP_SEARCH_URL=ws://localhost:8082

# Optimization Settings
# MCP_OPTIMIZATION_ENABLED=true
# MCP_MAX_CONTEXT_TOKENS=4000
# MCP_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Data Directory
# MCP_DATA_DIR=./data
# MCP_STATS_DIR=./data/stats

# Logging
# LOG_LEVEL=info
# LOG_FORMAT=json