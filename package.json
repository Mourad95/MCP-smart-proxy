{
  "name": "mcp-smart-proxy",
  "version": "1.0.0",
  "description": "Intelligent proxy for Model Context Protocol (MCP) that optimizes context usage and reduces token waste by 70-90%",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-smart-proxy": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:performance": "jest --testPathPattern=performance",
    "test:coverage": "jest --coverage",
    "benchmark": "node dist/benchmark/index.js",
    "benchmark:compare": "node dist/benchmark/compare.js",
    "maintenance": "node dist/scripts/maintenance.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "optimization",
    "proxy",
    "ai",
    "llm",
    "tokens",
    "context",
    "semantic-search",
    "vector",
    "embeddings"
  ],
  "author": "OpenClaw Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw-community/mcp-smart-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/openclaw-community/mcp-smart-proxy/issues"
  },
  "homepage": "https://github.com/openclaw-community/mcp-smart-proxy#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.16.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "vectra": "^0.3.0",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}