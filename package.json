{
  "name": "mcp-smart-proxy",
  "version": "1.0.0",
  "description": "Intelligent proxy for Model Context Protocol (MCP) that optimizes context usage and reduces token waste by 70-90%",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-smart-proxy": "dist/index.js"
  },
  "files": [
    "dist",
    "dashboard/dist",
    "config",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run build:healthcheck",
    "build:healthcheck": "tsc src/healthcheck.ts --outDir dist --module commonjs --target es2022",
    "start": "node dist/index.js start",
    "start:prod": "NODE_ENV=production node dist/index.js start --config ./config/production.json",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:performance": "jest --testPathPattern=performance",
    "test:coverage": "jest --coverage",
    "benchmark": "node dist/benchmark/index.js",
    "benchmark:compare": "node dist/benchmark/compare.js",
    "maintenance": "node dist/scripts/maintenance.js",
    "healthcheck": "node dist/healthcheck.js",
    "docker:build": "docker build -t mcp-smart-proxy:latest .",
    "docker:run": "docker run -p 3000:3000 -v mcp-data:/data mcp-smart-proxy:latest",
    "docker:compose": "docker-compose up -d",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build:full",
    "build:full": "npm run build && cd dashboard && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "optimization",
    "proxy",
    "ai",
    "llm",
    "tokens",
    "context",
    "semantic-search",
    "vector",
    "embeddings"
  ],
  "author": "OpenClaw Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mourad95/MCP-smart-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/Mourad95/MCP-smart-proxy/issues"
  },
  "homepage": "https://github.com/Mourad95/MCP-smart-proxy#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.16.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "vectra": "^0.3.0",
    "winston": "^3.11.0",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.5",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
